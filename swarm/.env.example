# =============================================================================
# Agent Swarm — Environment Variables
# =============================================================================
# Copy to .env and fill in your keys:
#   cp swarm/.env.example swarm/.env
# =============================================================================

# --- LLM Provider (used by MiroFish for agent reasoning) ---
LLM_API_KEY=your-openai-or-compatible-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# --- OpenAI (used by OpenViking for embeddings) ---
OPENAI_API_KEY=your-openai-api-key

# --- Anthropic (used by OpenViking VLM via LiteLLM) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Zep Cloud (used by MiroFish for memory graph) ---
ZEP_API_KEY=your-zep-cloud-api-key

# --- OpenViking Configuration ---
OPENVIKING_URL=http://localhost:1933
OPENVIKING_WORKSPACE=./viking_workspace
OPENVIKING_EMBED_PROVIDER=openai
OPENVIKING_EMBED_MODEL=text-embedding-3-large
OPENVIKING_VLM_PROVIDER=litellm
OPENVIKING_VLM_MODEL=claude-sonnet-4-20250514

# --- MiroFish Configuration ---
MIROFISH_URL=http://localhost:5001

# --- ABC Cards ---
ABC_CARDS_DIR=./cards
